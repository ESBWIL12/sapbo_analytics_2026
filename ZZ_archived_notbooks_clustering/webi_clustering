def main_global_doc_similarity(
    catalog="dataplatform01_central_dev_catalog_01",
    schema="silver_sap_bo",               # where the temp view lives
    concat_view="v_docid_concat",         # temp view created by main_concat
    out_schema="silver_sap_bo",           # output schema
    out_table="webi_metadata_cms_doc_global_similarity",
    num_neighbors=10,                     # top-K per document
    vocab_size=50000,
    min_df=2,
    bucket_length=2.0,                    # LSH bucket length (tune)
    num_hash_tables=6,                    # LSH tables (tune for recall/speed)
    filter_empty=True,                    # drop empty Combined_all
    cosine_threshold=None,                 # e.g., 0.85 to keep only strong matches
    logger=None
):
    """
    Compute global nearest neighbors between documents (one row per Document_Id), based on 'Combined_all' text.
    Writes {catalog}.{out_schema}.{out_table} with:
      - src_document_id, nbr_document_id, cosine_similarity, distance
    """
    from pyspark.sql import functions as F
    from pyspark.sql.window import Window
    from pyspark.ml.feature import RegexTokenizer, CountVectorizer, IDF, Normalizer, BucketedRandomProjectionLSH
    from pyspark.ml import Pipeline

    # 0) Setup

    spark.sql(f"USE CATALOG {catalog}")
    spark.sql(f"USE SCHEMA {schema}")
    spark.sql(f"CREATE SCHEMA IF NOT EXISTS {catalog}.{out_schema}")
    logger.info("Starts Clustering Docs")
    # 1) Load aggregated documents from the temp view
    df_docs = spark.table(concat_view).select("Document_Id", "Combined_all")
    if filter_empty:
        df_docs = df_docs.where(F.length(F.col("Combined_all")) > 0)

    # Unique row id for self-join filtering
    df_docs = df_docs.withColumn("id_row", F.monotonically_increasing_id())
    logger.info(f"Input structure for documents: {df_docs.dtypes}")
    # 2) Tokenize + TF-IDF + Normalize (unit vectors)
    tokenizer = RegexTokenizer(
        inputCol="Combined_all", outputCol="tokens",
        pattern=r"[^\w]+", toLowercase=True, minTokenLength=2
    )
    cv = CountVectorizer(inputCol="tokens", outputCol="tf", vocabSize=vocab_size, minDF=min_df)
    idf = IDF(inputCol="tf", outputCol="tfidf")
    normalizer = Normalizer(inputCol="tfidf", outputCol="vec_norm", p=2.0)
    logger.info(f"Completed prepare TF-IDF")

    pipe = Pipeline(stages=[tokenizer, cv, idf, normalizer])
    model = pipe.fit(df_docs)
    df_vec = model.transform(df_docs).select("id_row", "Document_Id", "vec_norm").cache()
    logger.info(f"Vector ready for cosumption")

    # 3) LSH ANN on normalized vectors (Euclidean -> cosine)
    lsh = BucketedRandomProjectionLSH(
        inputCol="vec_norm", outputCol="hashes",
        bucketLength=bucket_length, numHashTables=num_hash_tables
    )
    logger.info("prepared LSH Model to fit vectors")
    lsh_model = lsh.fit(df_vec)
    logger.info("Get ready to start Similarity join")

    sim_join = lsh_model.approxSimilarityJoin(
        df_vec, df_vec,
        threshold=float("inf"),
        distCol="distance"
    )
    logger.info("start to remove self-pairs")
    # Remove self-pairs
    sim_pairs = sim_join.where(F.col("datasetA.id_row") != F.col("datasetB.id_row"))
    logger.info("Prepare to convert L2 distance to cosine similarity")

    # Convert L2 distance on unit vectors to cosine similarity
    sim_pairs = sim_pairs.withColumn(
        "cosine_similarity",
        1.0 - (F.col("distance") * F.col("distance")) / 2.0
    )
    logger.info("Similarity join completed")
    # Flatten fields
    flat = sim_pairs.select(
        F.col("datasetA.Document_Id").alias("src_document_id"),
        F.col("datasetB.Document_Id").alias("nbr_document_id"),
        F.col("datasetA.id_row").alias("src_row_id"),
        F.col("datasetB.id_row").alias("nbr_row_id"),
        F.col("distance"),
        F.col("cosine_similarity")
    )
    logger.info("Flattened fields")

    # Optional threshold
    if cosine_threshold is not None:
        flat = flat.where(F.col("cosine_similarity") >= F.lit(float(cosine_threshold)))
    logger.info("Threshold applied, start to rank Top-K")
    # Rank top-K neighbors per source document
    w = Window.partitionBy("src_document_id").orderBy(F.col("cosine_similarity").desc_nulls_last())
    logger.info("Windows defined")
    topk = flat.withColumn("rk", F.row_number().over(w)) \
               .where(F.col("rk") <= F.lit(num_neighbors)) \
               .select("src_document_id", "nbr_document_id", "distance", "cosine_similarity")
    logger.info(f"Top-K neighbors {num_neighbors}")
    # 4) Persist results as a Delta table
    spark.sql(f"USE SCHEMA {out_schema}")
    logger.info("Write result into Delta table")
    topk.write.mode("overwrite").format("delta").saveAsTable(f"{catalog}.{out_schema}.{out_table}")
    logger.info(f"Result into Delta table{out_table}")

    # Optional optimize
    try:
        spark.sql(f"OPTIMIZE {catalog}.{out_schema}.{out_table} ZORDER BY (src_document_id)")
    except Exception as e:
        print(f"OPTIMIZE skipped: {e}")

    cnt = spark.table(f"{catalog}.{out_schema}.{out_table}").count()
    print(f"Global document similarity pairs written: {cnt:,}")
    return {
        "similarity_table": f"{catalog}.{out_schema}.{out_table}",
        "pairs": cnt,
        "num_neighbors": num_neighbors,
        "vocab_size": vocab_size,
        "min_df": min_df,
        "bucket_length": bucket_length,
               "num_hash_tables": num_hash_tables,
        "cosine_threshold": cosine_threshold
    }

    
