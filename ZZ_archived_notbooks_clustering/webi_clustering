def main_concat(
    catalog="dataplatform01_central_dev_catalog_01",
    schema="silver_sap_bo",   # or bronze_sap_bo_snp if reading directly from Bronze
    table="webi_metadata_cms_silver",  # use your source table name here
    output_view="v_docid_concat",
    row_delim="\n",            # delimiter between rows in the same Document_Id
    field_delim=" | " ,         # delimiter between fields inside a row
    logger=None
):
    """
    Build concatenation per Document_Id, ordered by SQL_Index (numeric).
    Produces a view with four columns of concatenations:
    - SQL_Query_all
    - DataSource_Name_all
    - Connection_Name_all
    - Combined_all (includes SQL_Index label + all fields)

    Returns: name of the created temp view.
    """
    from pyspark.sql import functions as F

    spark.sql(f"USE CATALOG {catalog}")
    spark.sql(f"USE SCHEMA {schema}")

    df = spark.table(f"{catalog}.{schema}.{table}").select(
        "Document_Id", "SQL_Index", "SQL_Query", "DataSource_Name", "Connection_Name"
    ).where(F.col("Document_Id").isNotNull())
    logger.info(f"Found {df.count()} rows in {table}")

    # Cast SQL_Index to int for proper ordering; null-safe sort keeps nulls last
    df2 = (
        df
        .withColumn("idx", F.col("SQL_Index").cast("int"))  # numeric order
        .withColumn("SQL_Query", F.coalesce(F.col("SQL_Query"), F.lit("")))
        .withColumn("DataSource_Name", F.coalesce(F.col("DataSource_Name"), F.lit("")))
        .withColumn("Connection_Name", F.coalesce(F.col("Connection_Name"), F.lit("")))
    )

    # Collect rows into an array of structs and sort by idx
    grouped = (
        df2.groupBy("Document_Id")
           .agg(F.array_sort(F.collect_list(F.struct(
                F.col("idx").alias("idx"),
                F.col("SQL_Query").alias("q"),
                F.col("DataSource_Name").alias("ds"),
                F.col("Connection_Name").alias("cn")
            ))).alias("rows"))
    )
    logger.info(f"Found {grouped.count()} groups")
    # Build per-field concatenations (ordered)
    result = (
        grouped.select(
            "Document_Id",
            F.expr(f"array_join(transform(rows, x -> x.q), '{row_delim}')").alias("SQL_Query_all"),
            F.expr(f"array_join(transform(rows, x -> x.ds), '{row_delim}')").alias("DataSource_Name_all"),
            F.expr(f"array_join(transform(rows, x -> x.cn), '{row_delim}')").alias("Connection_Name_all"),
            F.expr(
                "array_join("
                f"transform(rows, x -> concat('SQL_Index: ', coalesce(string(x.idx), ''), '{field_delim}', "
                "                       'SQL_Query: ', x.q, '{field_delim}', "
                "                       'DataSource_Name: ', x.ds, '{field_delim}', "
                "                       'Connection_Name: ', x.cn)"
                "), "
                f"'{row_delim}')"
            ).alias("Combined_all")
        )
    )
    logger.info(f"Created {result.count()} rows with {result.schema}"    )

    # Create a temp view for easy SQL access
    result.createOrReplaceTempView(output_view)
    logger.info(f"Created temp view: {output_view}")
    return output_view

